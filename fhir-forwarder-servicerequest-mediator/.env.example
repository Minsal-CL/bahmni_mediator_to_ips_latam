# ── FHIR Forwarder ServiceRequest Mediator ──────────────────────────────────
NODE_ENV=development
FORWARDER_SERVICEREQUEST_PORT=8016

# OpenHIM
OPENHIM_USER=mediator-proxy@openhim.org
OPENHIM_PASS=CHANGE_ME
OPENHIM_API_URL=https://10.68.174.206:8080

# Fuente: proxy FHIR de OpenMRS (lectura de Encounter/Observation/Patient/Practitioner)
FHIR_PROXY_URL=https://10.68.174.206:5000/proxy/fhir

# Destino: nodo nacional FHIR (PUT del ServiceRequest y referencias)
FHIR_NODE_URL=http://10.68.174.222

# ── IPS (ITI-67) — mismo origen que el dashboard "IPS LAC" ───────────────────
# Base regional contra la que se consulta el último DocumentReference del paciente
IPS_REGIONAL_BASE=https://apiopenhim.nodonacionalph4h-dev.minsal.cl/regional
IPS_TYPE_LOINC=60591-5
# Si no se definen, usa OPENHIM_USER/OPENHIM_PASS
IPS_BASIC_USER=mediator-proxy@openhim.org
IPS_BASIC_PASS=CHANGE_ME

# ── Constantes FHIR del ServiceRequest (obligatorias en R4) ──────────────────
SR_STATUS=active
SR_INTENT=order
SR_CATEGORY_TEXT=Interconsulta

# ── UUIDs de conceptos del formulario (override opcional) ────────────────────
# Por defecto usan los del formulario "Interconsulta Transfronteriza".
# SR_CONCEPT_REFERRED_TO=9bb0795c-4ff0-0305-1990-000000000042
# SR_CONCEPT_REASON_TEXT=164359AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# SR_CONCEPT_CLINICAL_HISTORY=9bb0795c-4ff0-0305-1990-000000000043
# SR_CONCEPT_COUNTRY_DEST=19110fa3-2243-4e7d-8092-afc525573f3a
# SR_CONCEPT_ORG_DEST=75cf9a9e-8bdf-4f76-a701-fa6f05f72e36

# Identificadores con los que se busca el IPS (ITI-67), en orden: RUN/RUT y luego Pasaporte
SR_NATIONAL_ID_TYPE_TEXT=Patient Identifier
SR_PASSPORT_ID_TYPE_TEXT=Pasaporte
