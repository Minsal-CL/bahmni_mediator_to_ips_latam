# ── MEOW QR Mediator ─────────────────────────────────────────────────────────
NODE_ENV=development
MEOW_PORT=8018

# OpenHIM
OPENHIM_USER=mediator-proxy@openhim.org
OPENHIM_PASS=CHANGE_ME
OPENHIM_API=https://10.68.174.206:8080

# Servicio firmador: operación $meow sobre Bundle/{id}
MEOW_BASE_URL=https://signer.nodonacionalph4h-dev.minsal.cl/fhir
# MEOW_BASIC_USER=
# MEOW_BASIC_PASS=

# Servicio de decodificación del HC1 (lacpass)
MEOW_DECODE_URL=http://lacpass.create.cl:7089/decode/hcert
# MEOW_DECODE_BASIC_USER=
# MEOW_DECODE_BASIC_PASS=

# Nivel de corrección de errores del QR generado: L | M | Q | H
MEOW_QR_ERROR_CORRECTION=M

# CORS (opcional, separado por comas)
CORS_ORIGIN=https://10.68.174.205,https://localhost
