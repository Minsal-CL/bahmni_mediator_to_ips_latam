# ── FHIR Forwarder MedicationStatement Mediator ─────────────────────────────
NODE_ENV=development
FORWARDER_MEDICATIONSTATEMENT_PORT=8017

# OpenHIM
OPENHIM_USER=mediator-proxy@openhim.org
OPENHIM_PASS=CHANGE_ME
OPENHIM_API_URL=https://10.68.174.206:8080

# Fuente: proxy FHIR de OpenMRS / Destino: nodo nacional FHIR
FHIR_PROXY_URL=https://10.68.174.206:5000/proxy/fhir
FHIR_NODE_URL=http://10.68.174.222

# ── Perfil IG RACSEL (https://ig.racsel.org/ReporteMedicamentos.html) ────────
MS_PROFILE_URL=http://racsel.org/StructureDefinition/LACMedicationStatementMeOw
# status del MedicationStatement (1..1): active|completed|intended|stopped|on-hold|...
MS_STATUS=active

# ── Fase 2: documento MHD (Composition + Document Bundle + DocumentReference) ──
# Si true, además de subir el MedicationStatement, ensambla y POSTea la transacción MHD (ITI-65)
MS_MHD_ENABLED=true
# Endpoint MHD donde se POSTea la transacción (default: ${FHIR_NODE_URL}/fhir). Para ITI-65 vía OpenHIM,
# apunta al canal correspondiente, p.ej. https://10.68.174.206:5000/lacpass/_iti65
MS_MHD_ENDPOINT=
# Organización autora del documento (Composition.author)
MS_AUTHOR_ORG_NAME=Hospital Clínico San Borja Arriarán
MS_AUTHOR_ORG_COUNTRY=CL

# ── UUIDs de conceptos del formulario "Reporte Medicamentos" (override opcional) ──
# MS_CONCEPT_MEDICATION=1282AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA   # Medicamento (Coded) -> medicationCodeableConcept
# MS_CONCEPT_DOSE_TEXT=165503AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA    # Dosis (Text) -> dosage.text
# MS_CONCEPT_ROUTE_TEXT=165502AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA   # Vía (Text) -> dosage.route.text
