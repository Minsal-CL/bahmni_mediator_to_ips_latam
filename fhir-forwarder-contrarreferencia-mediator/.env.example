# Forwarder Contrarreferencia Mediator (respuesta a Interconsulta) — ejemplo
FORWARDER_CONTRARREFERENCIA_PORT=8020
OPENHIM_CONTRARREFERENCIA_ENDPOINT=https://10.68.174.206:5000/forwardercontrarreferencia/_event

# Único servidor FHIR: nodo nacional (documento MHD + resolución del ServiceRequest)
CR_MHD_ENDPOINT=https://hapinacional.nodonacionalph4h-dev.minsal.cl/fhir
# (opcional) base FHIR nacional para buscar el SR / registrar Patient; por defecto = CR_MHD_ENDPOINT
# CR_NATIONAL_FHIR_BASE=https://hapinacional.nodonacionalph4h-dev.minsal.cl/fhir

# Perfiles IG RACSEL (variante IT)
CR_COMPOSITION_PROFILE=http://racsel.org/StructureDefinition/LACCompositionIT
CR_DOCBUNDLE_PROFILE=http://racsel.org/StructureDefinition/LACBundleDocIT
CR_DOCREF_PROFILE=http://racsel.org/StructureDefinition/LACDocReferenceIT
CR_TXBUNDLE_PROFILE=http://racsel.org/StructureDefinition/LACBundleTransactionMHDIT
CR_ORG_PROFILE_URL=http://racsel.org/StructureDefinition/LACOrganization
CR_MASTER_ID_SYSTEM=urn:ietf:rfc:3986

# Organización destino (autor de la contrarreferencia)
CR_AUTHOR_ORG_NAME=Hospital Clínico San Borja Arriarán
CR_AUTHOR_ORG_COUNTRY=CL

# Resolución del ServiceRequest (enlace de vuelta)
CR_SR_STATUS_FILTER=active
# Status al que se transiciona el ServiceRequest original al llegar su respuesta (PUT best-effort)
CR_SR_TARGET_STATUS=completed
CR_NATIONAL_ID_TYPE_TEXT=Patient Identifier
CR_PASSPORT_ID_TYPE_TEXT=Pasaporte
CR_REGISTER_PATIENT=true

# Concepto de disparo (form Contrarreferencia, obs Text "Resultado de la Evaluación")
CR_CONCEPT_EVAL=931c9e9c-5cb5-4f74-b7c3-e9952b9ac101
