CR_AUTHOR_ORG_NAME=Hospital Clínico San Borja Arriarán
CR_AUTHOR_ORG_COUNTRY=CL
# Resolución del ServiceRequest (enlace de vuelta best-effort)
CR_SR_STATUS_FILTER=active
CR_NATIONAL_ID_TYPE_TEXT=Patient Identifier
CR_PASSPORT_ID_TYPE_TEXT=Pasaporte
CR_REGISTER_PATIENT=true
# Concepto de disparo (form Contrarreferencia, obs Text "Resultado de la Evaluación")
CR_CONCEPT_EVAL=931c9e9c-5cb5-4f74-b7c3-e9952b9ac101

# Carpeta donde los mediadores dejan copia del bundle MHD enviado (montado ./tmp:/tmp en docker-compose)
MHD_DUMP_DIR=/tmp

